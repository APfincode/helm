# =============================================================================
# HYPER-ALPHA-ARENA V2 — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENV=development
# Options: development, staging, production

DEBUG=false
# Set to true ONLY for local debugging. Never in production.

# =============================================================================
# HYPERLIQUID EXCHANGE CREDENTIALS
# =============================================================================
HYPERLIQUID_WALLET=0xYOUR_WALLET_ADDRESS_HERE
HYPERLIQUID_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# NEVER share your private key. This is the only place it should exist.

# =============================================================================
# BINANCE FUTURES CREDENTIALS (optional, for backup/arbitrage)
# =============================================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# =============================================================================
# LLM API CREDENTIALS
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
# Or your preferred LLM provider

# =============================================================================
# TELEGRAM BOT
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get from @BotFather on Telegram

# Comma-separated list of allowed Telegram chat IDs
TELEGRAM_WHITELIST=123456789,987654321

# =============================================================================
# SECURITY
# =============================================================================
HMAC_SECRET_KEY=generate_a_random_64_char_hex_string_here
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite+aiosqlite:///data/trading_bot.db
# For development only. Production may use PostgreSQL.

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_FILE=logs/trading_bot.log
